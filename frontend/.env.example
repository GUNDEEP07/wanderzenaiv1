# Frontend environment variables for Vite
# Copy this file to .env and fill in your actual values

# API Gateway endpoint
VITE_API_URL=https://y44o2x9cu1.execute-api.ap-southeast-2.amazonaws.com/prod

# Stripe public key for payments
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# YouTube Data API key (for video search & enrichment)
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Foursquare API key (for venue recommendations)
VITE_FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Google Analytics (optional)
# VITE_GA_ID=G-XXXXXXXXXX
